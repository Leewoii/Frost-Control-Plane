{
  "name": "baryon-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:worker dev:web",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck",
    "test": "npm --workspaces --if-present run test"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^5.8.3"
  }
}
